BOT_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
DATABASE_PATH=./data/rides.db
LICENSE_DATABASE_PATH=./data/licenses.db
OSRM_URL=http://localhost:5000

# Dev/debug (optional)
WHITELIST_IDS=          # Comma-separated Telegram IDs; if set, bot ignores all other users
DEV_IDS=                # Comma-separated IDs allowed to use /dev menu; enables alt impersonation
ALT_COUNT=2             # Number of alt personas available in the dev menu
