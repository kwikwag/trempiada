BOT_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
DATABASE_PATH=./data/rides.db
LICENSE_DATABASE_PATH=./data/licenses.db
OSRM_URL=http://localhost:5000
AWS_REGION=eu-west-1
AWS_LIVENESS_ROLE_ARN=arn:aws:iam::123456789012:role/trempiada-liveness-browser
AWS_LIVENESS_BOOTSTRAP_TABLE=trempiada-liveness-bootstrap
AWS_LIVENESS_ROLE_SESSION_NAME=trempiada-liveness
AWS_LIVENESS_PAGES_URL=https://kwikwag.github.io/trempiada/liveness/
AWS_LIVENESS_TOKEN_TTL_SECONDS=180
AWS_LIVENESS_POLL_INTERVAL_SECONDS=15
AWS_LIVENESS_MAX_POLL_SECONDS=180
AWS_LIVENESS_CONFIDENCE_THRESHOLD=90
AWS_FACE_SIMILARITY_THRESHOLD=90
AWS_FACE_MIN_SHARPNESS=40
AWS_FACE_MIN_BRIGHTNESS=30
AWS_FACE_MAX_YAW=20
AWS_FACE_MAX_PITCH=20
AWS_FACE_MAX_ROLL=15
AWS_FACE_OUTPUT_SIZE=512
AWS_FACE_CROP_PADDING_RATIO=0.15

# Dev/debug (optional)
WHITELIST_IDS=          # Comma-separated Telegram IDs; if set, bot ignores all other users
DEV_IDS=                # Comma-separated IDs allowed to use /dev menu; enables alt impersonation
ALT_COUNT=2             # Number of alt personas available in the dev menu
