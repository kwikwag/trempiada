{
  "name": "trempiada-bot",
  "version": "0.1.0",
  "description": "Telegram ridesharing bot for Israel",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "dev:watch": "node --watch -r ts-node/register src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "eslint .",
    "liveness:local-link": "ts-node scripts/create_local_liveness_link.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && npm run hooks:install || true",
    "test": "node --test -r ts-node/register/transpile-only 'tests/unit/**/*.test.ts'",
    "test:e2e": "node --test -r ts-node/register/transpile-only 'tests/e2e/**/*.test.ts'",
    "test:integration": "node --test -r ts-node/register/transpile-only 'tests/integration/**/*.test.ts'",
    "test:all": "node --test -r ts-node/register/transpile-only 'tests/{unit,integration,e2e}/**/*.test.ts'",
    "test:unit": "npm test",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "pre-commit": "lint-staged --no-stage && npm run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json}": "prettier --write",
    "*.{ts,tsx,js,mjs}": "eslint"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1035.0",
    "@aws-sdk/client-rekognition": "^3.1035.0",
    "@aws-sdk/client-sts": "^3.1035.0",
    "@aws-sdk/lib-dynamodb": "^3.1035.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "lint-staged": "^15.5.1",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
