{
  "name": "trempiada-bot",
  "version": "0.1.0",
  "description": "Telegram ridesharing bot for Israel",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "test": "node --test -r ts-node/register/transpile-only 'tests/unit/**/*.test.ts'",
    "test:e2e": "node --test -r ts-node/register/transpile-only 'tests/e2e/**/*.test.ts'",
    "test:all": "node --test -r ts-node/register/transpile-only 'tests/{unit,e2e}/**/*.test.ts'"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
